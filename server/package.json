{
  "name": "baghdad-shop-server",
  "version": "1.0.0",
  "private": true,
  "description": "The backend side of Baghdad Shop. A robust REST API built with Node.js, Express, TypeScript, and MongoDB.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "tree": "tree -I 'node_modules|dist'",
    "server": "json-server db.json --port 5100",
    "mongo:start": "brew services start mongodb-community",
    "mongo:stop": "brew services stop mongodb-community",
    "seed:users": "tsx src/modules/user/user.seeder.ts -seed",
    "delete:users": "tsx src/modules/user/user.seeder.ts -delete",
    "migrate:products": "tsx src/modules/product/product.migrator.ts",
    "seed:products": "tsx src/modules/product/product.seeder.ts -seed",
    "delete:products": "tsx src/modules/product/product.seeder.ts -delete"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "mongodb",
    "clean-architecture",
    "rest-api"
  ],
  "author": "Hossam Gezo <ha2ghossam10@gmail.com> (https://github.com/HossamGezo)",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/HossamGezo/baghdad-shop/issues"
  },
  "homepage": "https://github.com/HossamGezo/baghdad-shop#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "json-server": "^1.0.0-beta.15",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
